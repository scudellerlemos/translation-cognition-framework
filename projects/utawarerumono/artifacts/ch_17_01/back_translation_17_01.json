      "verdict": "pass",
      "note": "Exato."
    },
    {
      "offset": "0xec9fb",
      "back_en": "The man takes Atuy's hand in his.",
      "verdict": "pass",
      "note": "Exato."
    },
    {
      "offset": "0xecc74",
      "back_en": "...Something is not right here.",
