    {
      "offset": "0xed61a",
      "back_en": "murmuring only a word of caution for me.",
      "verdict": "pass",
      "note": "Exato."
    },
    {
      "offset": "0xed676",
      "back_en": "buy a drink and listen in. Nothing to worry about.",
      "verdict": "pass",
      "note": "Exato."
    },
    {
      "offset": "0xed706",
      "back_en": "ruffians. They sit in the back, ordering drinks.",
