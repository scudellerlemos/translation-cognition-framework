    },
    {
      "offset": "0x184433",
      "back_en": "Shouldn't we call the guards or something...?",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x184d70",
      "back_en": "Mikado...",
      "verdict": "pass",
      "note": "Nome mantido."
    },
    {
      "offset": "0x184dad",
      "back_en": "that all of this was just a sham.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x184e21",
      "back_en": "special, even among the kamunagi.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x184fe5",
      "back_en": "\"Child of man, love thy knowledge. But beware that",
      "verdict": "pass",
      "note": "Tom arcaico preservado."
    },
    {
      "offset": "0x185018",
      "back_en": "thy curiosity bring not ruin to thee and thine.\"",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x1853bb",
      "back_en": "We shall accompany you in bed--",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x1853db",
      "back_en": "N-No, I won't allow it!",
      "verdict": "pass",
      "note": "Correto."
    },
    {
      "offset": "0x1854d7",
      "back_en": "His sexual preferences. In vivid detail.",
      "verdict": "pass",
      "note": "'preferências' cobre likes/dislikes."
    },
    {
      "offset": "0x185507",
      "back_en": "A-A-And that wasn't what I was talking about!",
      "verdict": "revise",
      "note": "Gagueira em 'E-E-E' sugere 'And'; deveria ser 'I-I-Isso'."
    },
    {
      "offset": "0x1855a5",
      "back_en": "positions.",
      "verdict": "pass",
      "note": "Correto."
    },
    {
      "offset": "0x1855db",
      "back_en": "What do you intend on doing with him!?",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x1857c4",
      "back_en": "For you, Master.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x185972",
      "back_en": "Rulutieh can?",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x1859d0",
      "back_en": "next to me, as if it's where they belong.",
      "verdict": "pass",
      "note": "Fiel; 'delas' correto."
    },
    {
      "offset": "0x185a2b",
      "back_en": "their warm touch...",
      "verdict": "revise",
      "note": "'deles' (masc.) deveria ser 'delas' referindo-se às garotas."
    },
    {
      "offset": "0x185a74",
      "back_en": "hugging me like this before, too.",
      "verdict": "pass",
      "note": "'clinging'→'abraçando' aceitável."
    },
    {
      "offset": "0x185f9a",
      "back_en": "Wh--H-Hey, where do you think you're wiping!?",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x186001",
      "back_en": "Hey, uh, no need to reach in there...",
      "verdict": "pass",
      "note": "Sentido mantido."
    },
    {
      "offset": "0x186043",
      "back_en": "C-Careful with all that, uh, touching--",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x18610d",
      "back_en": "so... if you could please take it off...",
      "verdict": "pass",
      "note": "Falta acento em 'tirá-lo' (menor)."
