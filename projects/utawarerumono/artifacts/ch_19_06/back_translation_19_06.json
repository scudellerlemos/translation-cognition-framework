{
  "entries": [
    {
      "offset": "0x183fbf",
      "back_en": "We shall keep this on until we reach our house.",
      "verdict": "pass",
      "note": "Sentido mantido; 'isso' por 'these' aceitável."
    },
    {
      "offset": "0x184146",
      "back_en": "An order?",
      "verdict": "pass",
      "note": "Correto."
    },
    {
      "offset": "0x18417e",
      "back_en": "We belong to you, Master.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x184198",
      "back_en": "We shall serve ourselves.",
      "verdict": "revise",
      "note": "'Nos serviremos' soa reflexivo; usar 'Nós serviremos'/'Iremos servir'."
    },
    {
      "offset": "0x1841a8",
      "back_en": "Our reason for existing is your satisfaction.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x1841d7",
      "back_en": "Orders are absolute.",
      "verdict": "pass",
      "note": "Correto."
    },
    {
      "offset": "0x18421e",
      "back_en": "the greatest joy, Master.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x18423f",
      "back_en": "They're... serious. It's not that they are, right.",
      "verdict": "revise",
      "note": "'Não é que sejam, né' está confuso; melhor 'Não estão, né?'"
    },
    {
      "offset": "0x1842cb",
      "back_en": "Orders of a sexual nature are permitted.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x1842f4",
      "back_en": "Orders of a sexual nature are highly recommended.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0x184326",
      "back_en": "Bfwah!?",
