      "offset": "0xdd4d6",
      "back_en": "inheritance.",
      "verdict": "pass",
      "note": "Correto."
    },
    {
      "offset": "0xdd616",
      "back_en": "bastard child.",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0xdd657",
      "back_en": "the scandal secret of the public?",
      "verdict": "revise",
      "note": "'secret from the public' mal traduzido."
    },
    {
      "offset": "0xdde1e",
      "back_en": "quite, young man.",
      "verdict": "revise",
      "note": "'enough'='já basta', não 'bastante'."
    },
    {
      "offset": "0xdde5d",
      "back_en": "fall into his hands...",
      "verdict": "pass",
      "note": "Fiel."
    },
    {
      "offset": "0xddede",
      "back_en": "She ought to be fine, left in his care.",
      "verdict": "revise",
      "note": "'deixado' deveria concordar fem. 'deixada'."
    },
    {
