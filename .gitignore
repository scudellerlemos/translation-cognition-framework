# Binários de jogo (assets com copyright) — nunca versionar
# O usuário entrega o .sdat localmente (artifacts/ ou via CLI); ver project.json.
*.sdat

# Artefatos de build do Python
__pycache__/
*.pyc

# Segredos — chave de API NUNCA versionada (use .env local; ver .env.example, esse SIM versionado)
.env
.env.local

# Regeneráveis 100% determinísticos do context_pack (saída de artifacts/<cena>/).
# São reconstruídos a cada run; não são entregável nem estado durável → não versionar
# (também elimina o churn de regeneração ao rodar os testes). Ver framework/docs/NAMING.md.
projects/*/artifacts/*/pack.json
projects/*/artifacts/*/scene_prompt.md
